{
  "realm_roles": [
    {
        "name": "user",
        "description": "Standard user with limited access"
    },
    {
        "name": "admin",
        "description": "Administrator with elevated privileges"
    },
    {
        "name": "orgAdmin",
        "description": "Organization administrator who manages users within their org"
    },
    {
        "name": "systemAdmin",
        "description": "System administrator with full access"
    }
  ],
  "policies": [
    {
      "name": "SystemAdmin-Access",
      "description": "Access restricted to system administrators",
      "roles": ["systemAdmin"]
    },
    {
      "name": "Administrators-Access",
      "description": "Access restricted to admins and system administrators",
      "roles": ["admin", "orgAdmin", "systemAdmin"]
    },
    {
      "name": "Public-Access",
      "description": "Access available to all users",
      "roles": ["user", "admin", "orgAdmin", "systemAdmin"]
    }
  ]
}
